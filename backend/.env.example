# Supabase project credentials
# Find these in your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret — must match the "JWT Secret" shown in Supabase → Settings → API
JWT_SECRET=your-jwt-secret

# SMTP credentials for email notifications
# For Gmail / Google Workspace: generate an App Password at
#   myaccount.google.com → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=solaiym.2022@scis.smu.edu.sg
SMTP_PASS=your-google-app-password
EMAIL_FROM=CarePets <solaiym.2022@scis.smu.edu.sg>
